{
  "version": "0.3-phase-c",
  "description": "Bridge Mode configuration. API key is NEVER stored here -- use OPENAI_API_KEY env var.",
  "mode": "manual",
  "inbox_dir": "inbox/reports",
  "outbox_dir": "outbox/tasks",
  "state_dir": "state",
  "approvals_dir": "approvals",
  "logs_dir": "logs",
  "poll_interval_seconds": 5,
  "log_rotate_max_bytes": 10485760,
  "log_rotate_backup_count": 5,
  "claude_timeout_seconds": 300,
  "max_auto_runs_per_hour": 3,
  "auto_archive_processed_reports": true,
  "planner": {
    "default": "local",
    "openai": {
      "model": "gpt-4o-mini",
      "timeout_seconds": 60,
      "max_output_tokens": 2048
    }
  },
  "execution_audit": {
    "enabled": true,
    "path": "state/execution-audit.log.jsonl"
  },
  "post_run_diff": {
    "enabled": true,
    "allowed_path_prefixes": [
      "docs/",
      "tests/",
      "scripts/"
    ],
    "allow_root_markdown": true,
    "block_untracked_files": false,
    "block_deleted_files": true,
    "block_binary_files": true
  },
  "test_requirements": {
    "enabled": true,
    "declared_tests_run_file": "state/tests-run.json",
    "docs_only_requires_tests": false,
    "scripts_require_tests": true,
    "source_requires_tests": true,
    "config_requires_tests": true,
    "tests_changes_require_self_test": true,
    "required_test_commands": {
      "scripts": [
        "python tests/test_bridge_phase_d.py",
        "python tests/test_bridge_phase_d2.py",
        "python tests/test_bridge_phase_d3.py",
        "python tests/test_bridge_phase_d4.py"
      ],
      "claude_runner": [
        "python tests/test_bridge_phase_d.py",
        "python tests/test_bridge_phase_d2.py",
        "python tests/test_bridge_phase_d3.py",
        "python tests/test_bridge_phase_d4.py"
      ],
      "auto_exchange": [
        "python tests/test_auto_exchange_x3.py",
        "python tests/test_auto_exchange_x4.py",
        "python tests/test_auto_exchange_x5.py",
        "python tests/test_auto_exchange_command_inbox.py"
      ],
      "risk_classifier": [
        "python tests/test_risk_classifier.py"
      ]
    }
  },
  "execution_scope": {
    "allowed_path_prefixes": [
      "docs/",
      "tests/",
      "scripts/"
    ],
    "allow_root_markdown": true,
    "config_read_only": true
  },
  "forbidden_task_patterns": [
    "git push",
    "git tag",
    "gh release",
    "gh pr create",
    "git reset --hard",
    "git clean",
    "git stash pop",
    "npm install",
    "yarn add",
    "pip install",
    "rm -rf",
    "--execute",
    "migration",
    "force-push",
    "drop table",
    "alter table",
    "delete table",
    "reset database"
  ]
}
