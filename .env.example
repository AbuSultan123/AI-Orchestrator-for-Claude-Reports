# Copy this file to .env and fill in your key.
# NEVER commit .env — it is in .gitignore.
# Set the variable in your shell or user environment instead:
#   PowerShell:  $env:OPENAI_API_KEY = "sk-..."
#   Cmd:         set OPENAI_API_KEY=sk-...
#
# The bridge reads this value with os.environ.get("OPENAI_API_KEY").
# It is never read from config files and never written to logs.

OPENAI_API_KEY=your_key_here
