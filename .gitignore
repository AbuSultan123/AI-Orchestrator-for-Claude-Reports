# Runtime artifacts -- overwritten on every orchestrator run
/NEXT_TASK.md
/APPROVAL_REQUEST.md
state/latest-report.md
state/latest-decision.json
state/NEXT_TASK.md
state/APPROVAL_REQUEST.md

# Bridge v0.3 runtime outputs (generated on each run)
state/bridge-status.json
state/bridge.pid
state/processed-hashes.json
state/processed/
logs/bridge.log
logs/openai-calls.log
logs/errors.log
logs/claude-run-*.log
outbox/tasks/*.md
approvals/PENDING_APPROVAL.md
approvals/APPROVED.flag
approvals/REJECTED.flag
approvals/archive/

# Auto-exchange X1/X2 runtime files (generated on each run; .gitkeep is tracked)
outbox/chatgpt-briefs/*.md
outbox/chatgpt-briefs/archive/*.md
inbox/chatgpt-commands/*.md
state/chatgpt-command-history/*.md

# E2-D runtime namespace (user-approved; runtime data, never committed)
inbox/e2/
outbox/e2/
state/e2-registry.json
state/e2-history/

# E2-G no-copy bridge runtime (generated locally; .gitkeep is tracked)
# (inbox/chatgpt-commands/*.md already ignored above)
outbox/claude-reports/*.md
state/bridge/*.json

# Secrets -- never commit
.env

# Python
__pycache__/
*.py[cod]
*.pyo
.Python
.pytest_cache/
venv/
.venv/
*.egg-info/

# Claude Code local workspace settings (machine-specific)
.claude/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
